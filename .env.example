# PathFinder — single environment file
#
# Copy to `.env` and fill in values:
#   cp .env.example .env
#
# Docker Compose and the API both read from this file.

# ── LLM Providers ────────────────────────────────────────────────────────────
# Set at least one provider: a cloud API key OR a local Ollama URL.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ── Embeddings ───────────────────────────────────────────────────────────────
# Embeddings use OpenAI by default. When no OpenAI key is set, falls back to
# Ollama automatically. Override with a custom OpenAI-compatible endpoint:
# EMBEDDINGS_BASE_URL=hhttp://host.docker.internal:11434/v1
# EMBEDDINGS_MODEL=nomic-embed-text

# ── Chat Mode ────────────────────────────────────────────────────────────────
# "default" = real LLM chat (requires at least one provider above)
# "mock" = fake LLM responses (no provider needed; used by E2E / local dev)
PATHFINDER_CHAT_PROVIDER=default

# ── Security ─────────────────────────────────────────────────────────────────
# 32+ characters. The default dev key works locally; set your own in production.
API_SECRET_KEY=change-me-32-chars-min-xxxx-xxxx

# ── Infrastructure (optional — docker-compose sets container-friendly defaults)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pathfinder
# REDIS_URL=redis://redis:6379/0
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ── VEuPathDB (optional) ────────────────────────────────────────────────────
# Custom site list and base URLs (default: bundled sites.yaml)
# VEUPATHDB_SITES_CONFIG=/path/to/my-sites.yaml
