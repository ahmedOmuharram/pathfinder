# PathFinder — single environment file
#
# Copy to `.env` and fill in values:
#   cp .env.example .env
#
# Docker Compose and the API both read from this file.

# ── LLM Providers ────────────────────────────────────────────────────────────
# Set at least one API key. OpenAI is required for RAG embeddings.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Chat Mode ────────────────────────────────────────────────────────────────
# "mock" = fake LLM responses (no API key needed; used by E2E / local dev)
# "default" = real LLM chat (requires at least one API key above)
PATHFINDER_CHAT_PROVIDER=default

# ── Security ─────────────────────────────────────────────────────────────────
# 32+ characters. The default dev key works locally; set your own in production.
API_SECRET_KEY=change-me-32-chars-min-xxxx-xxxx

# ── Infrastructure (optional — docker-compose sets container-friendly defaults)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pathfinder
# REDIS_URL=redis://redis:6379/0
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# ── VEuPathDB (optional) ────────────────────────────────────────────────────
# Custom site list and base URLs (default: bundled sites.yaml)
# VEUPATHDB_SITES_CONFIG=/path/to/my-sites.yaml
